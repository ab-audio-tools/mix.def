# Supabase Configuration
# Get your project URL and keys from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ⚠️ IMPORTANT: Keep this SECRET - only use in .env.local, NEVER commit to repository
# This key has full admin permissions. Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App Configuration
NEXT_PUBLIC_APP_NAME=Mix.def
NEXT_PUBLIC_MAX_FILE_SIZE=104857600

